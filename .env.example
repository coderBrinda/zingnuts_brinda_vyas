# Copy to .env in this directory before running: cp .env.example .env

# MySQL
MYSQL_ROOT_PASSWORD=rootpassword
MYSQL_DATABASE=pm_tracker
MYSQL_USER=pm_user
MYSQL_PASSWORD=pm_pass
# Host port if you uncomment mysql ports in docker-compose.yml
MYSQL_PORT=3307

# Backend
BACKEND_PORT=4000
JWT_SECRET=change-this-secret-in-production
JWT_EXPIRES_IN=24h
CORS_ORIGIN=http://localhost:3000

# Frontend (browser must reach the API on the host)
FRONTEND_PORT=3000
NEXT_PUBLIC_API_URL=http://localhost:4000/api/v1
